#!/usr/bin/env bash
set -euo pipefail

FLARE_HOST="${FLARE_HOST:-localhost}"
FLARE_PORT="${FLARE_PORT:-5050}"
FLARE_URL="http://${FLARE_HOST}:${FLARE_PORT}"

usage() {
  cat <<'USAGE'
Usage: flare <preset> [options]

Presets:
  flare alert                       Red edge flash
  flare success                     Green edge flash
  flare error                       Red edge flash (3 pulses)
  flare pulse                       Blue edge flash (3 pulses)

Nag (repeats until you interact):
  flare nag                         Nag with alert colors
  flare nag success                 Nag with success colors
  flare stop                        Stop nagging

Custom:
  flare custom '#FF8800'            Custom color
  flare custom '#FF8800' --pulses 3 Custom color with options

Options (custom mode):
  --pulses N       Number of pulses
  --duration N     Flash duration in seconds
  --thickness N    Edge thickness in pixels

Environment:
  FLARE_HOST       Hostname (default: localhost)
  FLARE_PORT       Port (default: 5050)
USAGE
  exit 1
}

[[ $# -lt 1 ]] && usage

PRESET="$1"; shift

case "$PRESET" in
  alert|success|error|pulse)
    curl -sf -X POST "${FLARE_URL}/trigger" \
      -H "Content-Type: application/json" \
      -d "{\"preset\":\"${PRESET}\"}" > /dev/null
    ;;
  nag)
    NAG_PRESET="${1:-alert}"; shift 2>/dev/null || true
    curl -sf -X POST "${FLARE_URL}/nag" \
      -H "Content-Type: application/json" \
      -d "{\"preset\":\"${NAG_PRESET}\"}" > /dev/null
    ;;
  stop)
    curl -sf -X POST "${FLARE_URL}/stop" \
      -H "Content-Type: application/json" \
      -d '{}' > /dev/null
    ;;
  custom)
    [[ $# -lt 1 ]] && { echo "Error: custom requires a color argument"; exit 1; }
    COLOR="$1"; shift
    JSON="{\"preset\":\"custom\",\"color\":\"${COLOR}\""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --pulses)    JSON="${JSON},\"pulses\":${2}"; shift 2 ;;
        --duration)  JSON="${JSON},\"duration\":${2}"; shift 2 ;;
        --thickness) JSON="${JSON},\"thickness\":${2}"; shift 2 ;;
        *) echo "Unknown option: $1"; exit 1 ;;
      esac
    done
    JSON="${JSON}}"
    curl -sf -X POST "${FLARE_URL}/trigger" \
      -H "Content-Type: application/json" \
      -d "${JSON}" > /dev/null
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    echo "Unknown preset: $PRESET"
    usage
    ;;
esac
